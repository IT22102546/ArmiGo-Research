generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  SUPER_ADMIN
  HOSPITAL_ADMIN
  PARENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum DeviceType {
  FINGER_GLOVE
  WRIST_BAND
  ELBOW_BRACE
  SHOULDER_SUPPORT
}

enum TherapyProgramStatus {
  ACTIVE
  COMPLETED
  PAUSED
  PENDING
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentType {
  ASSESSMENT
  THERAPY_SESSION
  FOLLOW_UP
  PARENT_TRAINING
}

enum MovementType {
  FLEXION
  EXTENSION
  ABDUCTION
  ADDUCTION
  CIRCUMDUCTION
  PRONATION
  SUPINATION
  RADIAL_DEVIATION
  ULNAR_DEVIATION
}

enum GameType {
  FINGER_FUN
  WRIST_WIZARDRY
  ELBOW_QUESTS
  SHOULDER_STRENGTH
  MIXED_ADVENTURE
}

enum HospitalType {
  GOVERNMENT
  PRIVATE
  SPECIALIZED_CHILDREN
  REHABILITATION_CENTER
  CLINIC
}

enum HospitalStatus {
  ACTIVE
  INACTIVE
  PENDING_APPROVAL
  SUSPENDED
}

// ============================================
// CORE MODELS
// ============================================

model User {
  id                String          @id @default(cuid())
  email             String?         @unique
  phone             String          @unique
  password          String
  firstName         String
  lastName          String
  role              UserRole
  status            UserStatus      @default(PENDING)
  avatar            String?
  dateOfBirth       DateTime? 
  
  // Common fields
  address           String?
  city              String?
  districtId        String?
  zoneId            String?
  
  // Audit fields
  lastLoginAt       DateTime?
  emailVerified     Boolean         @default(false)
  phoneVerified     Boolean         @default(false)
  deletedAt         DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  district          District?       @relation("UserDistrict", fields: [districtId], references: [id])
  zone              Zone?           @relation("UserZone", fields: [zoneId], references: [id])
  
  // Parent specific
  parentProfile     ParentProfile?
  
  // Hospital specific
  hospitalProfile   HospitalProfile?
  
  // Children (for parents)
  children          Child[]         @relation("ParentChildren")
  
  // Therapy sessions
  therapySessions   TherapySession[] @relation("UserTherapySessions")
  
  // Appointments
  appointments      Appointment[]   @relation("UserAppointments")
  
  // Device assignments
  deviceAssignments DeviceAssignment[] @relation("UserDeviceAssignments")
  
  // Hospital management (for super admin)
  managedHospitals  Hospital[]      @relation("HospitalCreatedBy")
  
  // Progress records
  progressRecords   ProgressRecord[] @relation("ProgressRecordUser")
  
  // Audit logs
  auditLogs         AuditLog[]      @relation("AuditLogUser")
  
  // Credential logs
  credentialLogs    CredentialLog[] @relation("CredentialLogUser")
  
  // Appointments created
  createdAppointments Appointment[] @relation("AppointmentCreatedBy")

  @@index([deletedAt])
  @@index([role, status])
  @@index([email])
  @@index([phone])
  @@map("users")
}

model ParentProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  occupation      String?
  preferredContact String? // PHONE, EMAIL, WHATSAPP
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  children        Child[]  @relation("ParentProfileChildren")

  @@map("parent_profiles")
}

// ============================================
// HOSPITAL MANAGEMENT (Super Admin controlled)
// ============================================

model Hospital {
  id                String          @id @default(cuid())
  name              String          @unique
  registrationNo    String          @unique
  type              HospitalType
  status            HospitalStatus  @default(PENDING_APPROVAL)
  
  // Contact Information
  email             String          @unique
  phone             String
  alternatePhone    String?
  website           String?
  
  // Address
  address           String
  city              String
  districtId        String
  zoneId            String?
  postalCode        String?
  
  // Administrative
  establishedYear   Int?
  licenseNumber     String?
  licenseExpiry     DateTime?
  bedCapacity       Int?
  specialization    String[]        // e.g., ["Pediatric", "Neurology", "Rehabilitation"]
  
  // Personnel
  totalDoctors      Int?
  totalTherapists   Int?
  totalStaff        Int?
  
  // Super Admin fields
  createdById       String          // Super Admin who created this hospital
  createdBy         User            @relation("HospitalCreatedBy", fields: [createdById], references: [id])
  
  // Generated credentials for hospital admin
  adminEmail        String          @unique  // Auto-generated email for hospital admin
  adminPassword     String?          // Temporary password (hashed) - null means not yet generated
  
  // Timestamps
  lastLoginAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  
  // Relations
  district          District        @relation("HospitalDistrict", fields: [districtId], references: [id])
  zone              Zone?           @relation("HospitalZone", fields: [zoneId], references: [id])
  
  // Hospital admin profile (the user account created for this hospital)
  adminProfile      HospitalProfile?
  
  // Sub hospitals under this main hospital
  subHospitals      SubHospital[]
  
  // Staff members
  staff             HospitalStaff[]
  
  // Children assigned to this hospital
  children          Child[]         @relation("HospitalChildren")
  
  // Appointments
  appointments      Appointment[]   @relation("HospitalAppointments")
  
  // Device inventory
  devices           Device[]        @relation("HospitalDevices")
  
  // Credential logs
  credentialLogs    CredentialLog[] @relation("HospitalCredentialLogs")

  @@index([status])
  @@index([districtId])
  @@index([zoneId])
  @@index([type])
  @@index([createdById])
  @@map("hospitals")
}

model HospitalProfile {
  id              String          @id @default(cuid())
  userId          String          @unique
  hospitalId      String          @unique  // Link to the Hospital model
  
  // Additional profile info
  department      String?
  designation     String?
  qualifications  String[]
  
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospital        Hospital        @relation(fields: [hospitalId], references: [id])

  @@map("hospital_profiles")
}

model SubHospital {
  id              String          @id @default(cuid())
  name            String
  registrationNo  String?         @unique
  hospitalId      String          // Parent main hospital
  
  // Contact
  email           String?
  phone           String
  alternatePhone  String?
  
  // Address
  address         String
  city            String
  districtId      String
  zoneId          String?
  
  // Type
  type            String?         // CLINIC, REHAB_CENTER, OUTREACH
  
  // Staff
  inChargeName    String?
  inChargePhone   String?
  totalStaff      Int?
  
  // Status
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relations
  parentHospital  Hospital        @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  district        District        @relation("SubHospitalDistrict", fields: [districtId], references: [id])
  zone            Zone?           @relation("SubHospitalZone", fields: [zoneId], references: [id])
  
  // Children assigned to this sub hospital
  children        Child[]         @relation("SubHospitalChildren")
  
  // Staff at this sub hospital
  staff           HospitalStaff[] @relation("SubHospitalStaff")
  
  // Appointments
  appointments    Appointment[]   @relation("SubHospitalAppointments")

  @@index([hospitalId])
  @@index([districtId])
  @@index([zoneId])
  @@index([isActive])
  @@map("sub_hospitals")
}

model HospitalStaff {
  id              String          @id @default(cuid())
  hospitalId      String          // Main hospital
  subHospitalId   String?         // Optional: if assigned to specific sub hospital
  
  // Personal info
  name            String
  role            String          // DOCTOR, THERAPIST, NURSE, ADMIN, TECHNICIAN
  specialization  String?
  
  // Contact
  phone           String
  email           String?
  
  // Professional
  employeeId      String?
  qualifications  String[]
  experience      Int?            // years
  
  // Status
  isActive        Boolean         @default(true)
  joinedAt        DateTime        @default(now())
  leftAt          DateTime?
  
  // Relations
  hospital        Hospital        @relation(fields: [hospitalId], references: [id])
  subHospital     SubHospital?    @relation("SubHospitalStaff", fields: [subHospitalId], references: [id])
  
  // Appointments/therapies they handle
  appointments    Appointment[]   @relation("StaffAppointments")

  @@index([hospitalId])
  @@index([subHospitalId])
  @@index([isActive])
  @@map("hospital_staff")
}

// ============================================
// CHILD / PARENT MANAGEMENT
// ============================================

model Child {
  id              String          @id @default(cuid())
  parentId        String
  hospitalId      String?
  subHospitalId   String?
  
  // Personal
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  age             Int
  gender          String
  
  // Medical
  diagnosis       String?         // e.g., "Hemiplegia - Left", "Hemiplegia - Right"
  diagnosisDate   DateTime?
  medicalNotes    String?
  assignedDoctor  String?         // Name or ID of primary doctor
  
  // Status
  isActive        Boolean         @default(true)
  enrolledAt      DateTime        @default(now())
  
  // Relations - with unique constraint names
  parent          User            @relation("ParentChildren", fields: [parentId], references: [id], map: "child_parent_fkey")
  parentProfile   ParentProfile?  @relation("ParentProfileChildren", fields: [parentId], references: [userId], map: "child_parent_profile_fkey")
  hospital        Hospital?       @relation("HospitalChildren", fields: [hospitalId], references: [id], map: "child_hospital_fkey")
  subHospital     SubHospital?    @relation("SubHospitalChildren", fields: [subHospitalId], references: [id], map: "child_subhospital_fkey")
  
  // Therapy related
  therapyPrograms TherapyProgram[]
  deviceAssignments DeviceAssignment[]
  progressRecords ProgressRecord[]
  therapySessions TherapySession[]
  appointments    Appointment[]
  
  @@index([parentId])
  @@index([hospitalId])
  @@index([subHospitalId])
  @@index([isActive])
  @@map("children")
}

// ============================================
// DEVICE MANAGEMENT
// ============================================

model Device {
  id              String          @id @default(cuid())
  hospitalId      String?         // Which hospital owns this device
  
  deviceType      DeviceType
  serialNumber    String          @unique
  modelNumber     String?
  manufacturer    String?
  firmwareVersion String?
  
  // Purchase info
  purchaseDate    DateTime?
  warrantyExpiry  DateTime?
  cost            Float?
  supplier        String?
  
  // Status
  status          String          @default("AVAILABLE") // AVAILABLE, ASSIGNED, MAINTENANCE, RETIRED
  condition       String?         // NEW, GOOD, FAIR, POOR
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  notes           String?
  
  // Relations
  hospital        Hospital?       @relation("HospitalDevices", fields: [hospitalId], references: [id])
  assignments     DeviceAssignment[]
  movementLogs    MovementLog[]
  therapySessions TherapySession[] @relation("TherapySessionDevice")

  @@index([status])
  @@index([deviceType])
  @@index([hospitalId])
  @@map("devices")
}

model DeviceAssignment {
  id              String          @id @default(cuid())
  deviceId        String
  childId         String
  assignedBy      String          // User ID (hospital staff)
  assignedAt      DateTime        @default(now())
  returnedAt      DateTime?
  isActive        Boolean         @default(true)
  notes           String?
  
  device          Device          @relation(fields: [deviceId], references: [id])
  child           Child           @relation(fields: [childId], references: [id])
  assignedByUser  User            @relation("UserDeviceAssignments", fields: [assignedBy], references: [id])
  
  @@unique([deviceId, childId, isActive])
  @@index([childId, isActive])
  @@index([deviceId, isActive])
  @@map("device_assignments")
}

// ============================================
// THERAPY PROGRAM MANAGEMENT
// ============================================

model TherapyProgram {
  id              String          @id @default(cuid())
  childId         String
  name            String
  description     String?
  startDate       DateTime
  endDate         DateTime?
  status          TherapyProgramStatus @default(ACTIVE)
  
  // Game settings
  gameType        GameType
  difficultyLevel String          // BEGINNER, INTERMEDIATE, ADVANCED
  targetMovements MovementType[]
  sessionDuration Int             // in minutes
  sessionsPerWeek Int
  
  // Progress tracking
  progressRecords ProgressRecord[]
  sessions        TherapySession[]
  
  child           Child           @relation(fields: [childId], references: [id])
  
  @@index([childId, status])
  @@map("therapy_programs")
}

model TherapySession {
  id              String          @id @default(cuid())
  childId         String
  programId       String?
  deviceId        String?
  
  // Session details
  sessionDate     DateTime
  startTime       DateTime?
  endTime         DateTime?
  duration        Int?            // in minutes
  
  // Game data
  gameType        GameType?
  gameLevel       String?
  score           Int?
  accuracy        Float?          // percentage
  completed       Boolean         @default(false)
  
  // Movement data
  movements       MovementLog[]
  
  // Session notes
  therapistNotes  String?
  parentNotes     String?
  createdById     String          // User who recorded the session
  
  child           Child           @relation(fields: [childId], references: [id])
  program         TherapyProgram? @relation(fields: [programId], references: [id])
  device          Device?         @relation("TherapySessionDevice", fields: [deviceId], references: [id])
  createdBy       User            @relation("UserTherapySessions", fields: [createdById], references: [id])
  
  @@index([childId, sessionDate])
  @@index([programId])
  @@index([deviceId])
  @@map("therapy_sessions")
}

model MovementLog {
  id              String          @id @default(cuid())
  sessionId       String
  deviceId        String
  movementType    MovementType
  timestamp       DateTime
  value           Float?          // angle, distance, strength value
  unit            String?         // degrees, kg, etc.
  duration        Int?            // milliseconds
  repetitions     Int?            // number of repetitions
  quality         Float?          // movement quality score (0-100)
  
  session         TherapySession  @relation(fields: [sessionId], references: [id])
  device          Device          @relation(fields: [deviceId], references: [id])
  
  @@index([sessionId])
  @@index([deviceId])
  @@index([movementType])
  @@map("movement_logs")
}

model ProgressRecord {
  id              String          @id @default(cuid())
  childId         String
  programId       String?
  recordDate      DateTime        @default(now())
  
  // Movement metrics
  movementType    MovementType
  baselineValue   Float?          // starting value
  currentValue    Float?          // current value
  targetValue     Float?          // target value
  improvement     Float?          // percentage improvement
  
  // Session metrics
  totalSessions   Int?
  completedSessions Int?
  averageScore    Float?
  bestScore       Float?
  
  // Notes
  notes           String?
  recordedById    String
  
  child           Child           @relation(fields: [childId], references: [id])
  program         TherapyProgram? @relation(fields: [programId], references: [id])
  recordedBy      User            @relation("ProgressRecordUser", fields: [recordedById], references: [id])
  
  @@index([childId, recordDate])
  @@index([programId])
  @@map("progress_records")
}

// ============================================
// APPOINTMENT MANAGEMENT
// ============================================

model Appointment {
  id              String          @id @default(cuid())
  childId         String
  hospitalId      String?
  subHospitalId   String?
  staffId         String?         // Hospital staff ID
  parentId        String
  
  // Appointment details
  appointmentType AppointmentType
  title           String
  description     String?
  scheduledDate   DateTime
  scheduledTime   String          // e.g., "10:30 AM"
  duration        Int             // in minutes
  status          SessionStatus   @default(SCHEDULED)
  
  // Location
  isOnline        Boolean         @default(false)
  meetingLink     String?
  location        String?
  
  // Notes
  notes           String?
  cancellationReason String?
  
  // Tracking
  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  child           Child           @relation(fields: [childId], references: [id])
  hospital        Hospital?       @relation("HospitalAppointments", fields: [hospitalId], references: [id])
  subHospital     SubHospital?    @relation("SubHospitalAppointments", fields: [subHospitalId], references: [id])
  staff           HospitalStaff?  @relation("StaffAppointments", fields: [staffId], references: [id])
  parent          User            @relation("UserAppointments", fields: [parentId], references: [id])
  createdBy       User            @relation("AppointmentCreatedBy", fields: [createdById], references: [id])
  
  @@index([childId, scheduledDate])
  @@index([hospitalId, scheduledDate])
  @@index([parentId, scheduledDate])
  @@index([status])
  @@map("appointments")
}

// ============================================
// LOCATION MODELS
// ============================================

model Province {
  id              String          @id @default(cuid())
  name            String          @unique
  code            String?         @unique
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  districts       District[]
  
  @@map("provinces")
}

model District {
  id              String          @id @default(cuid())
  name            String          @unique
  code            String?         @unique
  provinceId      String?
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  province        Province?       @relation(fields: [provinceId], references: [id])
  zones           Zone[]
  users           User[]          @relation("UserDistrict")
  hospitals       Hospital[]      @relation("HospitalDistrict")
  subHospitals    SubHospital[]   @relation("SubHospitalDistrict")
  
  @@map("districts")
}

model Zone {
  id              String          @id @default(cuid())
  name            String          @unique
  code            String?         @unique
  districtId      String?
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  district        District?       @relation(fields: [districtId], references: [id])
  users           User[]          @relation("UserZone")
  hospitals       Hospital[]      @relation("HospitalZone")
  subHospitals    SubHospital[]   @relation("SubHospitalZone")
  
  @@map("zones")
}

// ============================================
// SYSTEM MODELS
// ============================================

model SystemSettings {
  id              String          @id @default(cuid())
  key             String          @unique
  value           String
  description     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  updatedBy       String?
  
  @@map("system_settings")
}

model AuditLog {
  id              String          @id @default(cuid())
  userId          String?
  action          String
  resource        String
  resourceId      String?
  ipAddress       String?
  userAgent       String?
  oldValues       String?         @db.Text
  newValues       String?         @db.Text
  metadata        String?         @db.Text
  createdAt       DateTime        @default(now())
  
  user            User?           @relation("AuditLogUser", fields: [userId], references: [id])
  
  @@index([userId, createdAt])
  @@index([resource, resourceId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ============================================
// CREDENTIAL GENERATION LOGS
// ============================================

model CredentialLog {
  id              String          @id @default(cuid())
  hospitalId      String
  generatedById   String
  generatedAt     DateTime        @default(now())
  email           String
  passwordReset   Boolean         @default(false)
  lastUsedAt      DateTime?
  
  hospital        Hospital        @relation("HospitalCredentialLogs", fields: [hospitalId], references: [id])
  generatedBy     User            @relation("CredentialLogUser", fields: [generatedById], references: [id])
  
  @@index([hospitalId])
  @@index([generatedAt])
  @@map("credential_logs")
}